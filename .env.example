# Copy to ".env" in this folder (never commit .env)

# Email — Gmail: use an App Password, not your normal login password
SENDER_EMAIL=your@gmail.com
SENDER_PASSWORD=xxxx-xxxx-xxxx-xxxx
RECEIVER_EMAIL=admin@gmail.com

# Or use these names instead (same meaning):
# EXAMGUARD_EMAIL=
# EXAMGUARD_EMAIL_PASSWORD=
# EXAMGUARD_ALERT_EMAIL=

# Flask session signing (use a long random string in production)
SECRET_KEY=change-me-to-a-long-random-string
